# ──────────────────────────────────────────────────────────────
#  Farm Bot — .gitignore
# ──────────────────────────────────────────────────────────────

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# ── User-specific configuration (PRIVATE) ───────────────────
# This file contains personal paths and webhook URLs.
# Each user generates their own via setup_farm_bot.py.
user_config.py

# ── Project-generated files (created at runtime) ────────────
Bot_Scripts/screenshots/
Bot_Scripts/logs/
screenshots/
logs/

# ── ChromaDB vector database (environment-specific) ─────────
Bot_Scripts/knowledge/vector_db/
knowledge/vector_db/

# ── OS files ─────────────────────────────────────────────────
Thumbs.db
.DS_Store
desktop.ini

# ── Shortcuts (user-specific paths) ─────────────────────────
*.lnk

# ── Rainmeter (deprecated — not needed for bot operation) ───
Rainmeter_Skin/
